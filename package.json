{
  "name": "awake-screen",
  "displayName": "AwakeScreen",
  "description": "A lightweight VS Code extension that temporarily prevents screen off and auto sleep from the status bar.",
  "version": "0.9.0",
  "publisher": "Knworks",
  "repository": "https://github.com/Knworks/awake-screen",
  "license": "MIT",
  "icon": "images/awake-screen.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
    "keywords": [
    "sleep",
    "screen",
    "awake",
    "display"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:awake-screen.toggle",
    "onCommand:awake-screen.enable",
    "onCommand:awake-screen.disable"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "awake-screen.toggle",
        "title": "Keep Awake: Toggle"
      },
      {
        "command": "awake-screen.enable",
        "title": "Keep Awake: Enable"
      },
      {
        "command": "awake-screen.disable",
        "title": "Keep Awake: Disable"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
